{
  "name": "shadcn-ui-monorepo",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "postinstall": "node scripts/postinstall-codegen.mjs",
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:port": "bash scripts/dev.sh",
    "start-all": "bash scripts/start-all.sh",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "convex:dev": "pnpm --filter @workspace/backend dev",
    "convex:deploy": "pnpm --filter @workspace/backend deploy",
    "convex:dashboard": "pnpm --filter @workspace/backend dashboard",
    "vercel-build": "node scripts/vercel-build.mjs",
    "dev:mobile": "turbo dev:mobile",
    "build:mobile": "turbo build:mobile",
    "build:mobile:dev": "turbo build:mobile:dev"
  },
  "devDependencies": {
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^9.27.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "turbo": "^2.4.2",
    "typescript": "5.7.3"
  },
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "@opentelemetry/instrumentation": "0.213.0",
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3"
    }
  }
}
