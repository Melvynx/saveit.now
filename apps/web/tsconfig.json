{
  "extends": "@workspace/typescript-config/react-library.json",
  "compilerOptions": {
    "baseUrl": ".",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    // App (not a library): no declaration emit. Prevents TS from serializing
    // huge cross-package inferred types (e.g. Better Auth) it can't name.
    "declaration": false,
    "declarationMap": false,
    "paths": {
      "@/*": ["./src/*"],
      "@convex/*": ["../../packages/backend/convex/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "test/**/*",
    "**/*.test.*",
    "**/*.spec.*",
    "e2e/**/*",
    "vitest.config.ts",
    "playwright.config.ts",
    "scripts/**/*"
  ]
}
