{
  "extends": "@workspace/typescript-config/react-library.json",
  "compilerOptions": {
    "baseUrl": ".",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "test/**/*",
    "**/*.test.*",
    "**/*.spec.*",
    "e2e/**/*",
    "vitest.config.ts",
    "playwright.config.ts",
    "scripts/**/*"
  ]
}
