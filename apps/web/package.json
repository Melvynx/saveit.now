{
  "name": "web",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "build:web": "vite build",
    "start": "node .output/server/index.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "inngest:dev": "sh -c 'pnpm dlx inngest-cli@latest dev --no-discovery -u http://localhost:${PORT:-3000}/api/inngest'",
    "stripe:webhook": "sh -c 'stripe listen --forward-to http://localhost:${PORT:-3000}/api/webhooks/stripe'",
    "ts": "tsc --noEmit",
    "better-auth:generate": "pnpm dlx @better-auth/cli@latest generate --output ../../packages/database/prisma/schema.prisma",
    "test": "vitest",
    "test:ci": "pnpm --filter @workspace/database db:generate && vitest run",
    "test:e2e": "HEADLESS=false playwright test --ui",
    "test:e2e:ci": "HEADLESS=true playwright test --reporter=list",
    "test:search-performance": "tsx scripts/test-search-performance.ts",
    "test:database-queries": "tsx scripts/monitor-database-queries.ts",
    "test:search-simple": "tsx scripts/simple-search-test.ts",
    "test:search-neon": "tsx scripts/test-with-neon-db.ts",
    "test:search-direct": "tsx scripts/direct-performance-test.ts",
    "benchmark:search": "npm run test:search-direct",
    "migrate:preview-urls": "tsx scripts/migrate-preview-urls.ts"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.52",
    "@ai-sdk/provider": "^3.0.8",
    "@ai-sdk/react": "^3.0.136",
    "@aws-sdk/client-s3": "^3.1014.0",
    "@convex-dev/react-query": "^0.1.0",
    "@danielxceron/youtube-transcript": "^1.2.6",
    "@inngest/realtime": "^0.4.7",
    "@prisma/client": "6.19.2",
    "@react-email/components": "^0.1.1",
    "@react-email/render": "^1.4.0",
    "@react-email/tailwind": "^1.2.2",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.94.5",
    "@tanstack/react-router": "^1.170.15",
    "@tanstack/react-start": "^1.168.25",
    "@types/mime-types": "^2.1.4",
    "@upstash/redis": "^1.37.0",
    "@workspace/database": "workspace:*",
    "@workspace/ui": "workspace:*",
    "ai": "^6.0.134",
    "better-auth": "1.2.8",
    "canvas-confetti": "^1.9.4",
    "cheerio": "^1.2.0",
    "consola": "^3.4.2",
    "convex": "^1.40.0",
    "dayjs": "^1.11.20",
    "gray-matter": "^4.0.3",
    "html-to-image": "^1.11.13",
    "inngest": "^3.54.0",
    "lucide-react": "^0.475.0",
    "marked": "^16.4.2",
    "mime-types": "^3.0.2",
    "motion": "^12.38.0",
    "nanoid": "^5.1.7",
    "nitro": "3.0.260603-beta",
    "nuqs": "^2.8.9",
    "posthog-js": "^1.363.1",
    "posthog-node": "^4.18.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.0",
    "react-hotkeys-hook": "^5.2.4",
    "react-tweet": "^3.3.0",
    "react-use-measure": "^2.1.7",
    "resend": "^4.8.0",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "streamdown": "^2.5.0",
    "stripe": "17.7.0",
    "tchao": "^1.1.4",
    "turndown": "^7.2.2",
    "up-fetch": "^2.6.0",
    "use-stick-to-bottom": "^1.1.3",
    "vite": "^7.3.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^20.19.37",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-react": "^4.7.0",
    "@workspace/eslint-config": "workspace:^",
    "@workspace/typescript-config": "workspace:*",
    "cross-fetch": "^4.1.0",
    "dotenv": "^17.3.1",
    "jsdom": "^26.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vitest": "^1.6.1",
    "vitest-mock-extended": "^3.1.0"
  }
