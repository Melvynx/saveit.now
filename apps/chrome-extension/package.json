{
  "name": "chrome-extension",
  "version": "1.2.2",
  "private": true,
  "scripts": {
    "dev": "tsc --watch && node scripts/copy-assets.js --dev",
    "build": "trash dist 2>/dev/null || true && node scripts/copy-assets.js",
    "build:dev": "trash dist 2>/dev/null || true && node scripts/copy-assets.js --dev",
    "build:prod": "trash dist 2>/dev/null || true && node scripts/copy-assets.js",
    "package": "npm run build:prod && node scripts/package-extension.js",
    "package:dev": "npm run build:dev && node scripts/package-extension.js",
    "version:patch": "bunx bumpp patch package.json public/manifest.json && npm run package",
    "version:minor": "bunx bumpp minor package.json public/manifest.json && npm run package",
    "version:major": "bunx bumpp major package.json public/manifest.json && npm run package",
    "clean": "trash dist package 2>/dev/null || true"
  },
  "dependencies": {
    "better-auth": "1.2.8"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.246",
    "archiver": "^6.0.2",
    "esbuild": "^0.19.12",
    "typescript": "^5.8.3"
  }
}
