{
  "name": "chrome-extension",
  "version": "1.2.3",
  "private": true,
  "scripts": {
    "dev": "node scripts/copy-assets.js --dev --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --test --disable-warning=MODULE_TYPELESS_PACKAGE_JSON tests/*.test.ts",
    "check": "pnpm typecheck && pnpm test",
    "icons": "swift scripts/generate-icons.swift",
    "build": "pnpm build:prod",
    "build:dev": "pnpm check && node scripts/copy-assets.js --dev",
    "build:prod": "pnpm icons && pnpm check && node scripts/copy-assets.js",
    "package": "pnpm build:prod && node scripts/package-extension.js",
    "package:dev": "pnpm build:dev && node scripts/package-extension.js --dev",
    "version:patch": "bunx bumpp patch package.json public/manifest.json && pnpm package",
    "version:minor": "bunx bumpp minor package.json public/manifest.json && pnpm package",
    "version:major": "bunx bumpp major package.json public/manifest.json && pnpm package",
    "clean": "node scripts/copy-assets.js --clean-all"
  },
  "dependencies": {
    "better-auth": "1.2.8"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.246",
    "archiver": "^6.0.2",
    "esbuild": "^0.19.12",
    "typescript": "^5.8.3"
  }
}
