{
  "manifest_version": 3,
  "name": "SaveIt.now",
  "version": "1.2.3",
  "description": "Organize nothing. Find everything.",
  "author": "@melvynxdev",
  "homepage_url": "https://saveit.now",
  "action": {
    "default_icon": {
      "16": "images/icon16.png",
      "32": "images/icon32.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    },
    "default_title": "SaveIt.now"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["activeTab", "scripting", "contextMenus"],
  "host_permissions": ["https://saveit.now/*"],
  "icons": {
    "16": "images/icon16.png",
    "32": "images/icon32.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "images/icon48.png",
        "content.css",
        "fonts/instrument-serif-regular.woff2",
        "fonts/instrument-serif-italic.woff2"
      ],
      "matches": ["<all_urls>"]
    },
    {
      "resources": ["intercept.js"],
      "matches": ["https://youtube.com/*", "https://*.youtube.com/*"]
    }
  ]
}
