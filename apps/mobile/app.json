{
  "expo": {
    "name": "SaveIt",
    "slug": "saveit-mobile",
    "version": "3.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "saveit",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFDF8"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "now.saveit.saveitapp",
      "icon": "./assets/images/icon.png",
      "buildNumber": "2026061302"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FFFDF8"
      },
      "edgeToEdgeEnabled": true,
      "package": "now.saveit.saveitapp"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-share-intent",
        {
          "iosActivationRules": {
            "NSExtensionActivationSupportsWebURLWithMaxCount": 1,
            "NSExtensionActivationSupportsWebPageWithMaxCount": 1,
            "NSExtensionActivationSupportsImageWithMaxCount": 5,
            "NSExtensionActivationSupportsMovieWithMaxCount": 1,
            "NSExtensionActivationSupportsText": true
          },
          "androidIntentFilters": ["text/*", "image/*", "video/*"]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "d09eb4d5-85f0-4a4a-9b9e-5ca5cc19d4fa"
      }
    },
    "env": {
      "production": {
        "EXPO_PUBLIC_API_URL": "https://saveit.now",
        "EXPO_PUBLIC_CONVEX_URL": "https://tough-chameleon-916.convex.cloud",
        "EXPO_PUBLIC_CONVEX_SITE_URL": "https://tough-chameleon-916.convex.site"
      }
    }
  }
}
