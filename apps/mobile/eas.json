{
  "cli": {
    "version": ">= 6.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "resourceClass": "m-medium"
      },
      "android": {
        "gradleCommand": ":app:assembleDebug"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "resourceClass": "m-medium"
      }
    },
    "production": {
      "credentialsSource": "local",
      "pnpm": "10.4.1",
      "ios": {
        "image": "latest",
        "resourceClass": "m-medium"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://beta.saveit.now",
        "EXPO_PUBLIC_CONVEX_URL": "https://charming-spider-722.convex.cloud",
        "EXPO_PUBLIC_CONVEX_SITE_URL": "https://charming-spider-722.convex.site",
        "RN_PRIVACY_MANIFEST_AGGREGATION": "false",
        "EX_DEV_CLIENT_NETWORK_INSPECTOR": "false"
      }
    },
    "melvynmal": {
      "distribution": "internal",
      "ios": {
        "resourceClass": "m-medium"
      },
      "env": {
        "RN_PRIVACY_MANIFEST_AGGREGATION": "false"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6749254685"
      }
    }
  }
}
