{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "PORT",
    "PLAYWRIGHT_CHROMIUM_CHANNEL",
    "PLAYWRIGHT_TEST_OTP_CODE"
  ],
  "ui": "tui",
  "tasks": {
    "build": {
      "env": [
        "VITE_CONVEX_URL",
        "VITE_CONVEX_SITE_URL",
        "VITE_STRIPE_PUBLISHABLE_KEY",
        "VITE_ENABLE_VIRTUALIZATION",
        "CONVEX_DEPLOYMENT",
        "CONVEX_URL",
        "CONVEX_SITE_URL",
        "CONVEX_DEPLOY_KEY",
        "VERCEL_PROJECT_PRODUCTION_URL",
        "VERCEL_URL",
        "VERCEL_ENV",
        "NODE_ENV",
        "CI",
        "HEADLESS",
        "NITRO_PRESET",
        "PLAYWRIGHT_TEST_BASE_URL"
      ],
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".output/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "test": {
      "dependsOn": ["^test"]
    },
    "test:ci": {
      "dependsOn": ["^test:ci"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "dev:mobile": {
      "cache": false,
      "persistent": true
    },
    "build:mobile": {
      "env": ["EXPO_PUBLIC_CONVEX_URL", "EXPO_PUBLIC_CONVEX_SITE_URL"],
      "cache": false,
      "outputs": []
    },
    "build:mobile:dev": {
      "env": ["EXPO_PUBLIC_CONVEX_URL", "EXPO_PUBLIC_CONVEX_SITE_URL"],
      "cache": false,
      "outputs": []
    },
    "build:web": {
      "env": [
        "VITE_CONVEX_URL",
        "VITE_CONVEX_SITE_URL",
        "VITE_STRIPE_PUBLISHABLE_KEY",
        "VITE_ENABLE_VIRTUALIZATION",
        "CONVEX_DEPLOYMENT",
        "CONVEX_URL",
        "CONVEX_SITE_URL",
        "CONVEX_DEPLOY_KEY",
        "VERCEL_PROJECT_PRODUCTION_URL",
        "VERCEL_URL",
        "VERCEL_ENV",
        "NODE_ENV",
        "CI",
        "HEADLESS",
        "NITRO_PRESET"
      ],
      "cache": false
    }
  }
}
