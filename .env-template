# ============================================================================
# SaveIt env template — copy the CLIENT block to apps/web/.env (+ apps/mobile/.env)
# and set the SERVER/BACKEND block on the Convex deployment via:
#     pnpm --filter @workspace/backend exec convex env set KEY value
# (or `pnpm scripts/convex-sync-env.sh` to push everything below from .env -> Convex).
# Nothing here is Prisma/Inngest/Redis — the entire backend is Convex.
# ============================================================================

# ----- apps/web/.env (client, must be VITE_*) -----
VITE_CONVEX_URL=https://<deployment>.convex.cloud
VITE_CONVEX_SITE_URL=https://<deployment>.convex.site
VITE_STRIPE_PUBLISHABLE_KEY=
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com
# Web SSR auth cookie prefix — must equal the Convex BETTER_AUTH_COOKIE_PREFIX
BETTER_AUTH_COOKIE_PREFIX=save-it

# ----- apps/mobile/.env -----
EXPO_PUBLIC_CONVEX_URL=https://<deployment>.convex.cloud
EXPO_PUBLIC_CONVEX_SITE_URL=https://<deployment>.convex.site

# ----- Convex backend env (set via `convex env set`, NOT committed) -----
# Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_COOKIE_PREFIX=save-it
SITE_URL=http://localhost:3000
BETTER_AUTH_TRUSTED_ORIGINS=
APPSTORE_TEST_EMAIL=
# OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_APP_BUNDLE_IDENTIFIER=
# AI (Gemini summaries / embeddings / chat)
GOOGLE_GENERATIVE_AI_API_KEY=
OPENAI_API_KEY=
# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_YEARLY_PRICE_ID=
STRIPE_COUPON_ID=
# Email (Resend)
RESEND_API_KEY=
RESEND_EMAIL_FROM=
HELP_EMAIL=
# Storage (Cloudflare R2 via S3 SDK)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=
AWS_ENDPOINT=
R2_URL=
# Cloudflare Browser Rendering (screenshots / PDF)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
# Analytics (optional, server-side)
POSTHOG_API_KEY=
